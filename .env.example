# browser-search-resilient local configuration
# Copy this file to .env and set the required tokens before running Docker Compose.

# Host port exposed on 127.0.0.1 by compose.yaml.
BROWSER_SEARCH_PORT=8088

# Optional API key for the browser-search HTTP/SSE endpoints.
# Leave blank for loopback-only local development; set when exposing beyond localhost.
BROWSER_SEARCH_API_KEY=

# Required by compose.yaml. Generate with: openssl rand -hex 32
CAMOFOX_API_KEY=

# Required when CRAWL4AI_ENABLED=true. Generate with: openssl rand -hex 32
CRAWL4AI_TOKEN=

# Crawl4AI extraction backend. Compose defaults this to true.
CRAWL4AI_ENABLED=true
CRAWL4AI_TIMEOUT_MS=45000
CRAWL4AI_PAGE_TIMEOUT_MS=45000
CRAWL4AI_MAX_SCROLL_STEPS=3
CRAWL4AI_SCAN_FULL_PAGE=false

# CloakBrowser fallback. Set CLOAK_ENABLED=false if you do not have a license.
CLOAK_ENABLED=true
CLOAKBROWSER_LICENSE_KEY=
CLOAK_PROXY=http://egress-proxy:3128
CLOAK_GEOIP=false
CLOAK_HEADLESS=false
CLOAK_HUMANIZE=true
CLOAK_TIMEZONE=America/Los_Angeles
CLOAK_LOCALE=en-US

# Runtime tuning.
DIRECT_TIMEOUT_MS=20000
BROWSER_TIMEOUT_MS=45000
CHALLENGE_WAIT_MS=20000
BROWSER_CONCURRENCY=2
RESEARCH_CONCURRENCY=4
MAX_RESPONSE_BYTES=5000000
DEFAULT_MAX_CHARACTERS=50000
MAX_MAX_CHARACTERS=200000

# Optional rate limiting. 0 disables the limiter.
RATE_LIMIT_RPM=0
RATE_LIMIT_BURST=0

# Optional in-process response cache.
CACHE_ENABLED=false
CACHE_TTL_MS=60000
CACHE_MAX_ENTRIES=256

# Optional robots.txt enforcement.
ROBOTS_ENABLED=false
ROBOTS_CACHE_TTL_MS=3600000

# Optional user-agent override for direct HTTP and sidecar browser fetches.
WEB_USER_AGENT=Mozilla/5.0 (compatible; ResilientBrowserSearch/0.2; +https://github.com/actual-human)
