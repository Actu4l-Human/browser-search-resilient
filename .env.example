# Required. Generate with: openssl rand -hex 32
CAMOFOX_API_KEY=replace-with-a-random-secret

# Required for network deployments. MCP and /v1/* calls require Authorization: Bearer <value>.
# Generate with: openssl rand -hex 32
BROWSER_SEARCH_API_KEY=replace-with-a-second-random-secret

BROWSER_SEARCH_PORT=8088
CLOAK_ENABLED=true

# Optional CloakBrowser Pro activation. The local egress proxy keeps the home
# residential WAN IP while adding DNS pinning and private-address filtering.
CLOAKBROWSER_LICENSE_KEY=
CLOAK_PROXY=http://egress-proxy:3128
CLOAK_GEOIP=false
CLOAK_HEADLESS=false
CLOAK_HUMANIZE=true
CLOAK_TIMEZONE=America/Los_Angeles
CLOAK_LOCALE=en-US

DIRECT_TIMEOUT_MS=20000
BROWSER_TIMEOUT_MS=45000
CHALLENGE_WAIT_MS=20000

BROWSER_CONCURRENCY=2
RESEARCH_CONCURRENCY=4
MAX_RESPONSE_BYTES=5000000

# Optional. Per-peer rate limiting (requests/minute). 0 disables. When the
# service sits behind LiteLLM, all traffic may share the LiteLLM peer address.
RATE_LIMIT_RPM=0
RATE_LIMIT_BURST=0

# Optional. In-memory response caching for fetch/search. Disabled by default.
CACHE_ENABLED=false
CACHE_TTL_MS=60000

# Optional. Honor robots.txt for the direct backend. Off by default for backwards compatibility.
ROBOTS_ENABLED=false
