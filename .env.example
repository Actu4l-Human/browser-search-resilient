# Required. Generate with: openssl rand -hex 32
CAMOFOX_API_KEY=replace-with-a-random-secret

# Strongly recommended. When set, MCP and /v1/* calls require Authorization: Bearer <value>.
# Generate with: openssl rand -hex 32
BROWSER_SEARCH_API_KEY=replace-with-a-second-random-secret

BROWSER_SEARCH_PORT=8088
CLOAK_ENABLED=true

# Optional CloakBrowser Pro activation and recommended server-controlled settings.
CLOAKBROWSER_LICENSE_KEY=
CLOAK_PROXY=
CLOAK_GEOIP=true
CLOAK_HEADLESS=false
CLOAK_TIMEZONE=America/Los_Angeles
CLOAK_LOCALE=en-US

DIRECT_TIMEOUT_MS=20000
BROWSER_TIMEOUT_MS=45000
CHALLENGE_WAIT_MS=20000

BROWSER_CONCURRENCY=2
RESEARCH_CONCURRENCY=4
MAX_RESPONSE_BYTES=5000000
