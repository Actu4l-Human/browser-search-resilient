# Required. Generate with: openssl rand -hex 32
CAMOFOX_API_KEY=replace-with-a-random-secret

# Optional. When set, MCP and /v1/* calls require Authorization: Bearer <value>.
# Generate with: openssl rand -hex 32
BROWSER_SEARCH_API_KEY=

BROWSER_SEARCH_PORT=8088
CLOAK_ENABLED=true

# Optional CloakBrowser Pro activation and server-controlled proxy.
CLOAKBROWSER_LICENSE_KEY=
CLOAK_PROXY=
CLOAK_GEOIP=false
CLOAK_HEADLESS=true

BROWSER_CONCURRENCY=2
RESEARCH_CONCURRENCY=4
MAX_RESPONSE_BYTES=5000000
