{
  "name": "@actual-human/resilient-browser-search",
  "version": "0.1.0",
  "private": false,
  "description": "Deterministic MCP web search and retrieval with SearXNG, direct HTTP, Camofox, and CloakBrowser fallbacks.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx src/http.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:egress-proxy": "node dist/egress-proxy.js"
  },
  "dependencies": {
    "@modelcontextprotocol/fastify": "2.0.0-beta.2",
    "@modelcontextprotocol/node": "2.0.0-beta.2",
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "cloakbrowser": "0.4.7",
    "fastify": "5.9.0",
    "mmdb-lib": "3.0.2",
    "playwright-core": "1.61.0",
    "socks-proxy-agent": "10.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
